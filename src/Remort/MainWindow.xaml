<ui:FluentWindow x:Class="Remort.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:devices="clr-namespace:Remort.Devices"
        xmlns:settings="clr-namespace:Remort.Settings"
        Title="Remort"
        Width="1024"
        Height="768"
        ExtendsContentIntoTitleBar="True"
        WindowBackdropType="Mica">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="Remort" />

            <ui:NavigationView x:Name="NavigationView"
                               Grid.Row="1"
                               PaneDisplayMode="Left"
                               OpenPaneLength="200"
                               IsBackButtonVisible="Collapsed"
                               IsTopSeparatorVisible="False"
                               IsFooterSeparatorVisible="False">
                <ui:NavigationView.MenuItems>
                    <ui:NavigationViewItem Content="Favorites"
                                           Icon="{ui:SymbolIcon Star24}"
                                           TargetPageType="{x:Type devices:FavoritesPage}" />
                    <ui:NavigationViewItem Content="Devices"
                                           Icon="{ui:SymbolIcon Desktop24}"
                                           TargetPageType="{x:Type devices:DevicesPage}" />
                </ui:NavigationView.MenuItems>
                <ui:NavigationView.FooterMenuItems>
                    <ui:NavigationViewItem Content="Settings"
                                           Icon="{ui:SymbolIcon Settings24}"
                                           TargetPageType="{x:Type settings:SettingsPage}" />
                </ui:NavigationView.FooterMenuItems>
        </ui:NavigationView>
    </Grid>
</ui:FluentWindow>
