<Window x:Class="Remort.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wf="clr-namespace:System.Windows.Forms.Integration;assembly=WindowsFormsIntegration"
        Title="Remort"
        Width="1024"
        Height="768">
    <Window.InputBindings>
        <KeyBinding Key="Right" Modifiers="Ctrl+Alt" Command="{Binding SwitchToNextDesktopCommand}" />
        <KeyBinding Key="Left" Modifiers="Ctrl+Alt" Command="{Binding SwitchToPreviousDesktopCommand}" />
    </Window.InputBindings>
    <DockPanel Background="{DynamicResource PrimaryBackground}">
        <!-- Connection bar -->
        <StackPanel DockPanel.Dock="Top"
                    Orientation="Horizontal"
                    Background="{DynamicResource SecondaryBackground}"
                    Margin="4">
            <TextBox x:Name="HostnameTextBox"
                     Width="300"
                     Margin="0,0,4,0"
                     VerticalContentAlignment="Center"
                     Text="{Binding Hostname, UpdateSourceTrigger=PropertyChanged}"
                     IsEnabled="{Binding ConnectionState, Converter={StaticResource DisconnectedToBoolConverter}}" />
            <Button Content="Connect"
                    Margin="0,0,4,0"
                    Padding="12,4"
                    Command="{Binding ConnectCommand}" />
            <Button Content="Disconnect"
                    Padding="12,4"
                    Command="{Binding DisconnectCommand}" />
            <Separator Margin="8,0" />
            <TextBlock Text="Max retries:"
                       VerticalAlignment="Center"
                       Margin="0,0,4,0" />
            <TextBox Width="40"
                     VerticalContentAlignment="Center"
                     Text="{Binding MaxRetryCount, UpdateSourceTrigger=LostFocus}"
                     IsEnabled="{Binding ConnectionState, Converter={StaticResource DisconnectedToBoolConverter}}" />
            <Separator Margin="8,0" />
            <CheckBox Content="Reconnect on sign-in"
                      VerticalAlignment="Center"
                      IsChecked="{Binding AutoReconnectEnabled}"
                      IsEnabled="{Binding ConnectionState, Converter={StaticResource DisconnectedToBoolConverter}}" />
            <Separator Margin="8,0" />
            <CheckBox Content="Pin to desktop"
                      VerticalAlignment="Center"
                      IsChecked="{Binding PinToDesktopEnabled}" />
            <Separator Margin="8,0" />
            <CheckBox Content="Reconnect on desktop switch"
                      VerticalAlignment="Center"
                      IsChecked="{Binding ReconnectOnDesktopSwitchEnabled}"
                      IsEnabled="{Binding PinToDesktopEnabled}"
                      ToolTip="Requires 'Pin to desktop' to be enabled" />
            <Separator Margin="8,0" />
            <TextBlock Text="Desktop:"
                       VerticalAlignment="Center"
                       Margin="0,0,4,0"
                       Visibility="{Binding IsDesktopSwitcherSupported, Converter={StaticResource BooleanToVisibilityConverter}}" />
            <ComboBox Width="140"
                      VerticalAlignment="Center"
                      ItemsSource="{Binding DesktopList}"
                      SelectedItem="{Binding CurrentDesktop, Mode=TwoWay}"
                      DisplayMemberPath="Name"
                      Visibility="{Binding IsDesktopSwitcherSupported, Converter={StaticResource BooleanToVisibilityConverter}}" />
        </StackPanel>

        <!-- Status bar -->
        <StatusBar DockPanel.Dock="Bottom"
                   Background="{DynamicResource SecondaryBackground}">
            <StatusBarItem>
                <TextBlock Text="{Binding StatusText}" />
            </StatusBarItem>
            <StatusBarItem Visibility="{Binding PinToDesktopEnabled, Converter={StaticResource BooleanToVisibilityConverter}}">
                <TextBlock Text="\uD83D\uDCCC" ToolTip="Pinned to this virtual desktop" />
            </StatusBarItem>
            <StatusBarItem HorizontalAlignment="Right">
                <Button x:Name="ThemeButton" Content="🎨" ToolTip="Theme Settings" Padding="8,2" Click="ThemeButton_Click" />
            </StatusBarItem>
        </StatusBar>

        <!-- RDP host area -->
        <wf:WindowsFormsHost x:Name="RdpHost" />
    </DockPanel>
</Window>
