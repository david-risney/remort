<Page x:Class="Remort.DeviceWindow.GeneralPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      Title="General">
    <ScrollViewer Margin="24" VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="480">
            <TextBlock Text="General"
                       FontSize="28"
                       FontWeight="SemiBold"
                       Margin="0,0,0,24" />
            <TextBlock Text="Name" Margin="0,0,0,4" />
            <ui:TextBox Text="{Binding Name, UpdateSourceTrigger=LostFocus}" Margin="0,0,0,12" />
            <TextBlock Text="Hostname" Margin="0,0,0,4" />
            <ui:TextBox Text="{Binding Hostname, UpdateSourceTrigger=LostFocus}" Margin="0,0,0,16" />
            <CheckBox Content="Autohide title bar"
                      IsChecked="{Binding AutohideTitleBar}"
                      Margin="0,0,0,8" />
            <CheckBox Content="Favorite"
                      IsChecked="{Binding IsFavorite}" />
        </StackPanel>
    </ScrollViewer>
</Page>
