<Page x:Class="Remort.DeviceWindow.DisplayPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Display">
    <ScrollViewer Margin="24" VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="480">
            <TextBlock Text="Display"
                       FontSize="28"
                       FontWeight="SemiBold"
                       Margin="0,0,0,24" />
            <CheckBox Content="Pin to virtual desktop"
                      IsChecked="{Binding PinToVirtualDesktop}"
                      Margin="0,0,0,8" />
            <CheckBox Content="Fit session to window"
                      IsChecked="{Binding FitSessionToWindow}"
                      Margin="0,0,0,8" />
            <CheckBox Content="Use all monitors when fullscreen"
                      IsChecked="{Binding UseAllMonitors}" />
        </StackPanel>
    </ScrollViewer>
</Page>
