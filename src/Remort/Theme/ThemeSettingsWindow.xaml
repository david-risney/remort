<Window x:Class="Remort.Theme.ThemeSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:theme="clr-namespace:Remort.Theme"
        Title="Theme Settings"
        Width="460"
        Height="560"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource PrimaryBackground}">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </Window.Resources>
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0"
                   Text="Color Profiles"
                   FontSize="18"
                   FontWeight="SemiBold"
                   Margin="0,0,0,12" />

        <!-- Profile list -->
        <ListBox Grid.Row="1"
                 ItemsSource="{Binding Profiles}"
                 SelectedItem="{Binding SelectedProfile, Mode=TwoWay}"
                 Background="{DynamicResource SecondaryBackground}"
                 BorderBrush="{DynamicResource Border}"
                 Margin="0,0,0,8">
            <ListBox.ItemTemplate>
                <DataTemplate DataType="{x:Type theme:ColorProfile}">
                    <StackPanel Orientation="Horizontal" Margin="4">
                        <TextBlock Text="{Binding Name}"
                                   VerticalAlignment="Center"
                                   Width="120" />
                        <Rectangle Width="16" Height="16" Margin="2,0">
                            <Rectangle.Fill>
                                <SolidColorBrush Color="{Binding PrimaryBackground}" />
                            </Rectangle.Fill>
                        </Rectangle>
                        <Rectangle Width="16" Height="16" Margin="2,0">
                            <Rectangle.Fill>
                                <SolidColorBrush Color="{Binding SecondaryBackground}" />
                            </Rectangle.Fill>
                        </Rectangle>
                        <Rectangle Width="16" Height="16" Margin="2,0">
                            <Rectangle.Fill>
                                <SolidColorBrush Color="{Binding Accent}" />
                            </Rectangle.Fill>
                        </Rectangle>
                        <Rectangle Width="16" Height="16" Margin="2,0">
                            <Rectangle.Fill>
                                <SolidColorBrush Color="{Binding TextPrimary}" />
                            </Rectangle.Fill>
                        </Rectangle>
                        <Rectangle Width="16" Height="16" Margin="2,0">
                            <Rectangle.Fill>
                                <SolidColorBrush Color="{Binding TextSecondary}" />
                            </Rectangle.Fill>
                        </Rectangle>
                        <Rectangle Width="16" Height="16" Margin="2,0">
                            <Rectangle.Fill>
                                <SolidColorBrush Color="{Binding Border}" />
                            </Rectangle.Fill>
                        </Rectangle>
                        <TextBlock Text="(preset)"
                                   Margin="8,0,0,0"
                                   FontStyle="Italic"
                                   Foreground="{DynamicResource TextSecondary}"
                                   VerticalAlignment="Center"
                                   Visibility="{Binding IsPreset, Converter={StaticResource BoolToVis}}" />
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!-- Edit panel (visible when editing) -->
        <StackPanel Grid.Row="2"
                    Visibility="{Binding IsEditing, Converter={StaticResource BoolToVis}}"
                    Margin="0,0,0,8">
            <TextBlock Text="Edit Colors" FontWeight="SemiBold" Margin="0,0,0,8" />

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="24" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="Primary Background" Margin="0,2,8,2" VerticalAlignment="Center" />
                <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding EditPrimaryBackground, UpdateSourceTrigger=PropertyChanged}" Margin="0,2" />
                <Rectangle Grid.Row="0" Grid.Column="2" Width="16" Height="16" Margin="4,2">
                    <Rectangle.Fill>
                        <SolidColorBrush Color="{Binding EditPrimaryBackground, FallbackValue=#000000}" />
                    </Rectangle.Fill>
                </Rectangle>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="Secondary Background" Margin="0,2,8,2" VerticalAlignment="Center" />
                <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding EditSecondaryBackground, UpdateSourceTrigger=PropertyChanged}" Margin="0,2" />
                <Rectangle Grid.Row="1" Grid.Column="2" Width="16" Height="16" Margin="4,2">
                    <Rectangle.Fill>
                        <SolidColorBrush Color="{Binding EditSecondaryBackground, FallbackValue=#000000}" />
                    </Rectangle.Fill>
                </Rectangle>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="Accent" Margin="0,2,8,2" VerticalAlignment="Center" />
                <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding EditAccent, UpdateSourceTrigger=PropertyChanged}" Margin="0,2" />
                <Rectangle Grid.Row="2" Grid.Column="2" Width="16" Height="16" Margin="4,2">
                    <Rectangle.Fill>
                        <SolidColorBrush Color="{Binding EditAccent, FallbackValue=#000000}" />
                    </Rectangle.Fill>
                </Rectangle>

                <TextBlock Grid.Row="3" Grid.Column="0" Text="Text Primary" Margin="0,2,8,2" VerticalAlignment="Center" />
                <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding EditTextPrimary, UpdateSourceTrigger=PropertyChanged}" Margin="0,2" />
                <Rectangle Grid.Row="3" Grid.Column="2" Width="16" Height="16" Margin="4,2">
                    <Rectangle.Fill>
                        <SolidColorBrush Color="{Binding EditTextPrimary, FallbackValue=#000000}" />
                    </Rectangle.Fill>
                </Rectangle>

                <TextBlock Grid.Row="4" Grid.Column="0" Text="Text Secondary" Margin="0,2,8,2" VerticalAlignment="Center" />
                <TextBox Grid.Row="4" Grid.Column="1" Text="{Binding EditTextSecondary, UpdateSourceTrigger=PropertyChanged}" Margin="0,2" />
                <Rectangle Grid.Row="4" Grid.Column="2" Width="16" Height="16" Margin="4,2">
                    <Rectangle.Fill>
                        <SolidColorBrush Color="{Binding EditTextSecondary, FallbackValue=#000000}" />
                    </Rectangle.Fill>
                </Rectangle>

                <TextBlock Grid.Row="5" Grid.Column="0" Text="Border" Margin="0,2,8,2" VerticalAlignment="Center" />
                <TextBox Grid.Row="5" Grid.Column="1" Text="{Binding EditBorder, UpdateSourceTrigger=PropertyChanged}" Margin="0,2" />
                <Rectangle Grid.Row="5" Grid.Column="2" Width="16" Height="16" Margin="4,2">
                    <Rectangle.Fill>
                        <SolidColorBrush Color="{Binding EditBorder, FallbackValue=#000000}" />
                    </Rectangle.Fill>
                </Rectangle>
            </Grid>

            <StackPanel Orientation="Horizontal" Margin="0,8,0,0" HorizontalAlignment="Right">
                <Button Content="Save" Command="{Binding SaveProfileCommand}" Padding="12,4" Margin="0,0,8,0" />
                <Button Content="Cancel" Command="{Binding CancelEditCommand}" Padding="12,4" />
            </StackPanel>
        </StackPanel>

        <!-- Bottom buttons -->
        <StackPanel Grid.Row="3" Orientation="Horizontal">
            <StackPanel Orientation="Horizontal" Margin="0,0,8,0">
                <TextBox Width="140" Text="{Binding NewProfileName, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,4,0" />
                <Button Content="New Profile" Command="{Binding CreateProfileCommand}" Padding="8,4" />
            </StackPanel>
            <Button Content="Edit"
                    Command="{Binding EditProfileCommand}"
                    Padding="8,4"
                    Margin="0,0,4,0"
                    x:Name="EditButton" />
            <Button Content="Delete"
                    Command="{Binding DeleteProfileCommand}"
                    Padding="8,4"
                    Margin="0,0,4,0"
                    x:Name="DeleteButton" />
            <TextBlock Text="{Binding NameValidationError}"
                       Foreground="Red"
                       VerticalAlignment="Center"
                       Margin="8,0,0,0" />
            <Button Content="Close"
                    Command="{Binding CloseCommand}"
                    Padding="12,4"
                    HorizontalAlignment="Right"
                    Margin="8,0,0,0" />
        </StackPanel>
    </Grid>
</Window>
