<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Design-time defaults (Dark preset). Overridden at runtime by ThemeService. -->
    <SolidColorBrush x:Key="PrimaryBackground" Color="#1E1E1E" />
    <SolidColorBrush x:Key="SecondaryBackground" Color="#252526" />
    <SolidColorBrush x:Key="Accent" Color="#007ACC" />
    <SolidColorBrush x:Key="TextPrimary" Color="#CCCCCC" />
    <SolidColorBrush x:Key="TextSecondary" Color="#808080" />
    <SolidColorBrush x:Key="Border" Color="#3F3F46" />
</ResourceDictionary>
