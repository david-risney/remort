<ui:FluentWindow x:Class="Remort.Devices.AddDeviceDialog"
                xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                Title="Add Device"
                Width="400"
                Height="280"
                WindowStartupLocation="CenterOwner"
                ResizeMode="NoResize"
                ExtendsContentIntoTitleBar="True"
                WindowBackdropType="Mica">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock Text="Device Name" Margin="0,0,0,4" />
            <ui:TextBox x:Name="NameTextBox"
                        PlaceholderText="e.g. My Dev Box"
                        Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                        KeyDown="TextBox_KeyDown" />

            <TextBlock Text="Hostname" Margin="0,12,0,4" />
            <ui:TextBox x:Name="HostnameTextBox"
                        PlaceholderText="e.g. devbox-1.devbox.microsoft.com"
                        Text="{Binding Hostname, UpdateSourceTrigger=PropertyChanged}"
                        KeyDown="TextBox_KeyDown" />

            <TextBlock Text="{Binding ValidationError}"
                       Foreground="Red"
                       Margin="0,8,0,0"
                       TextWrapping="Wrap"
                       Visibility="{Binding ValidationError, Converter={StaticResource StringToVisibilityConverter}}" />
        </StackPanel>

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <ui:Button x:Name="OkButton"
                       Content="OK"
                       Appearance="Primary"
                       Margin="0,0,8,0"
                       IsEnabled="{Binding CanConfirm}"
                       Click="OkButton_Click" />
            <ui:Button Content="Cancel"
                       Click="CancelButton_Click" />
        </StackPanel>
    </Grid>
</ui:FluentWindow>
