<Page x:Class="Remort.Devices.DevicesPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:devices="clr-namespace:Remort.Devices"
      Title="Devices">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
            <TextBlock Text="Devices"
                       FontSize="28"
                       FontWeight="SemiBold"
                       VerticalAlignment="Center" />
            <ui:Button Content="Add Device"
                       Icon="{ui:SymbolIcon Add24}"
                       Appearance="Primary"
                       Margin="16,0,0,0"
                       Command="{Binding AddDeviceCommand}" />
        </StackPanel>

        <ItemsControl Grid.Row="1"
                       ItemsSource="{Binding Devices}">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <WrapPanel />
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate DataType="{x:Type devices:DeviceCardViewModel}">
                    <ui:CardAction Margin="4"
                                   Width="220"
                                   Height="140"
                                   Command="{Binding OpenCommand}">
                        <ui:CardAction.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="Toggle Favorite" Command="{Binding ToggleFavoriteCommand}" />
                                <Separator />
                                <MenuItem Header="Remove Device" Command="{Binding RemoveCommand}" />
                            </ContextMenu>
                        </ui:CardAction.ContextMenu>
                        <Grid>
                            <Border CornerRadius="8"
                                    Background="{Binding BackgroundBrush}"
                                    Opacity="0.3" />
                            <ui:SymbolIcon Symbol="Star24"
                                           Visibility="{Binding IsFavorite, Converter={StaticResource BooleanToVisibilityConverter}}"
                                           HorizontalAlignment="Right"
                                           VerticalAlignment="Top"
                                           Margin="0,8,8,0"
                                           FontSize="16" />
                            <StackPanel VerticalAlignment="Bottom" Margin="12">
                                <TextBlock Text="{Binding Name}"
                                           FontSize="16"
                                           FontWeight="SemiBold"
                                           TextTrimming="CharacterEllipsis"
                                           MaxWidth="180" />
                            </StackPanel>
                        </Grid>
                    </ui:CardAction>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </Grid>
</Page>
