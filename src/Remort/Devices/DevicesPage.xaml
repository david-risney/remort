<Page x:Class="Remort.Devices.DevicesPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:devices="clr-namespace:Remort.Devices"
      Title="Devices">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
            <TextBlock Text="Devices"
                       FontSize="28"
                       FontWeight="SemiBold"
                       VerticalAlignment="Center" />
            <ui:Button Content="Add Device"
                       Icon="{ui:SymbolIcon Add24}"
                       Appearance="Primary"
                       Margin="16,0,0,0"
                       Command="{Binding AddDeviceCommand}" />
        </StackPanel>

        <ItemsControl Grid.Row="1"
                       ItemsSource="{Binding Devices}">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <WrapPanel />
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate DataType="{x:Type devices:DeviceCardViewModel}">
                    <Button Margin="4"
                            Width="220"
                            Height="140"
                            Command="{Binding OpenCommand}"
                            Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="CardBorder"
                                        CornerRadius="8"
                                        Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                                        BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                                        BorderThickness="1"
                                        ClipToBounds="True">
                                    <ContentPresenter HorizontalAlignment="Stretch"
                                                      VerticalAlignment="Stretch" />
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="CardBorder" Property="Background"
                                                Value="{DynamicResource CardBackgroundFillColorSecondaryBrush}" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                        <Grid>
                            <Border CornerRadius="8"
                                    Background="{Binding BackgroundBrush}"
                                    Opacity="0.3" />
                            <StackPanel Orientation="Horizontal"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Top"
                                        Margin="0,4,4,0">
                                <Button Command="{Binding ToggleFavoriteCommand}"
                                        Click="CardButton_Click"
                                        Background="Transparent"
                                        BorderBrush="Transparent"
                                        Padding="4"
                                        Cursor="Hand">
                                    <ui:SymbolIcon Symbol="Star24" FontSize="16">
                                        <ui:SymbolIcon.Style>
                                            <Style TargetType="ui:SymbolIcon">
                                                <Setter Property="Filled" Value="False" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsFavorite}" Value="True">
                                                        <Setter Property="Filled" Value="True" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </ui:SymbolIcon.Style>
                                    </ui:SymbolIcon>
                                </Button>
                                <Button Click="MoreButton_Click"
                                        Background="Transparent"
                                        BorderBrush="Transparent"
                                        Padding="4"
                                        Cursor="Hand">
                                    <Button.ContextMenu>
                                        <ContextMenu>
                                            <MenuItem Header="Toggle Favorite" Command="{Binding ToggleFavoriteCommand}" />
                                            <Separator />
                                            <MenuItem Header="Remove Device" Command="{Binding RemoveCommand}" />
                                        </ContextMenu>
                                    </Button.ContextMenu>
                                    <ui:SymbolIcon Symbol="MoreHorizontal24" FontSize="16" />
                                </Button>
                            </StackPanel>
                            <StackPanel VerticalAlignment="Bottom" Margin="12">
                                <TextBlock Text="{Binding Name}"
                                           FontSize="16"
                                           FontWeight="SemiBold"
                                           TextTrimming="CharacterEllipsis"
                                           MaxWidth="180" />
                            </StackPanel>
                        </Grid>
                    </Button>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </Grid>
</Page>
