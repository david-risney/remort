<Window x:Class="Remort.DevBox.DevBoxSelectionDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Select Dev Box"
        Width="420"
        Height="300"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <DockPanel Margin="12">
        <TextBlock DockPanel.Dock="Top"
                   Margin="0,0,0,8"
                   Text="Multiple Dev Boxes match. Select one:"
                   TextWrapping="Wrap" />
        <StackPanel DockPanel.Dock="Bottom"
                    HorizontalAlignment="Right"
                    Orientation="Horizontal"
                    Margin="0,8,0,0">
            <Button Content="Connect"
                    Padding="16,4"
                    Margin="0,0,8,0"
                    IsDefault="True"
                    Click="OnConnectClick" />
            <Button Content="Cancel"
                    Padding="16,4"
                    IsCancel="True"
                    Click="OnCancelClick" />
        </StackPanel>
        <ListBox x:Name="DevBoxListBox"
                 DisplayMemberPath="DisplayText"
                 SelectedIndex="0" />
    </DockPanel>
</Window>
